generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum FriendRequestPolicy {
  EVERYONE
  SHARED_CHANNELS
  NOBODY
}

enum ChannelStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ChannelRole {
  OWNER
  MODERATOR
  MEMBER
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

model User {
  id                  String              @id @default(cuid())
  email               String
  emailNormalized     String              @unique
  nickname            String
  nicknameNormalized  String              @unique
  passwordHash        String
  emailVerifiedAt     DateTime?
  status              UserStatus          @default(ACTIVE)
  friendRequestPolicy FriendRequestPolicy @default(EVERYONE)
  allowDirectMessages Boolean             @default(true)
  showOnline          Boolean             @default(true)
  showLastSeen        Boolean             @default(true)
  lastSeenAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  sessions             AuthSession[]
  verificationTokens   EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  createdChannels      Channel[]           @relation("ChannelCreator")
  channelMemberships   ChannelMembership[]
  channelFavourites    ChannelFavourite[]
  channelMessages      ChannelMessage[]    @relation("ChannelMessageSender")
  friendshipRequests   Friendship[]        @relation("FriendshipRequester")
  friendshipResponses  Friendship[]        @relation("FriendshipRecipient")
  conversationsAsA     DirectConversation[] @relation("ConversationMemberA")
  conversationsAsB     DirectConversation[] @relation("ConversationMemberB")
  sentDirectMessages   DirectMessage[]     @relation("DirectMessageSender")
  receivedDirectMessages DirectMessage[]   @relation("DirectMessageRecipient")
}

model AuthSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  lastSeenAt DateTime @default(now())
  userAgent String?
  ipHash    String?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Channel {
  id                    String        @id @default(cuid())
  slug                  String        @unique
  name                  String
  topic                 String?
  language              String        @default("pl")
  createdByUserId       String?
  isOfficial            Boolean       @default(false)
  isUnlisted            Boolean       @default(false)
  allowGuests           Boolean       @default(true)
  maxMembers            Int           @default(200)
  slowModeSeconds       Int           @default(0)
  protectedFromExpiry   Boolean       @default(false)
  status                ChannelStatus @default(ACTIVE)
  lastActivityAt        DateTime      @default(now())
  archivedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  creator     User?               @relation("ChannelCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  memberships ChannelMembership[]
  favourites  ChannelFavourite[]
  messages    ChannelMessage[]

  @@index([status, lastActivityAt])
  @@index([createdByUserId])
}

model ChannelMembership {
  id        String      @id @default(cuid())
  channelId String
  userId    String
  role      ChannelRole @default(MEMBER)
  joinedAt  DateTime    @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelFavourite {
  userId    String
  channelId String
  autoJoin  Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([userId, autoJoin, position])
}

model ChannelMessage {
  id             String    @id @default(cuid())
  channelId      String
  senderUserId   String?
  senderNickname String
  text           String
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  reportedAt     DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User?   @relation("ChannelMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([channelId, createdAt])
  @@index([senderUserId, createdAt])
}

model Friendship {
  id          String           @id @default(cuid())
  pairKey     String           @unique
  requesterId String
  recipientId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  respondedAt DateTime?
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User @relation("FriendshipRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([requesterId, status])
  @@index([recipientId, status])
}

model DirectConversation {
  id        String   @id @default(cuid())
  pairKey   String   @unique
  memberAId String
  memberBId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberA  User            @relation("ConversationMemberA", fields: [memberAId], references: [id], onDelete: Cascade)
  memberB  User            @relation("ConversationMemberB", fields: [memberBId], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@index([memberAId, updatedAt])
  @@index([memberBId, updatedAt])
}

model DirectMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  recipientId    String
  text           String
  createdAt      DateTime  @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  deletedAt      DateTime?

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient    User               @relation("DirectMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([recipientId, readAt, createdAt])
}
